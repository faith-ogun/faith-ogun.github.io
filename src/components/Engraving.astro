---
/*
  Placeholder engraved line-art motifs — scattered as collage decoration until
  Faith's ChatGPT-generated engravings replace them. Stroke uses currentColor so
  colour/opacity is controlled by the parent.
  Usage: <Engraving name="helix" class="illo" style="..." />
*/
export interface Props {
  name: 'helix' | 'chip' | 'moth' | 'neuron' | 'scope' | 'atom' | 'flask';
  class?: string;
  style?: string;
}
const { name, class: cls = '', style = '' } = Astro.props;
---
{name === 'helix' && (
  <svg class={cls} style={style} viewBox="0 0 80 200" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
    <path d="M20 6 C60 32, 20 56, 60 82 S20 132, 60 158 S20 200, 60 200" />
    <path d="M60 6 C20 32, 60 56, 20 82 S60 132, 20 158 S60 200, 20 200" />
    <g stroke-width="1.1">
      <line x1="26" y1="22" x2="54" y2="22"/><line x1="30" y1="44" x2="50" y2="44"/>
      <line x1="26" y1="70" x2="54" y2="70"/><line x1="30" y1="96" x2="50" y2="96"/>
      <line x1="26" y1="122" x2="54" y2="122"/><line x1="30" y1="148" x2="50" y2="148"/>
    </g>
  </svg>
)}
{name === 'chip' && (
  <svg class={cls} style={style} viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
    <rect x="34" y="34" width="52" height="52" rx="2"/>
    <rect x="48" y="48" width="24" height="24" rx="1"/>
    <g stroke-width="1.1">
      <path d="M48 48h-14M48 56h-20M48 64h-14M48 72h-20"/>
      <path d="M72 48h14M72 56h20M72 64h14M72 72h20"/>
      <path d="M48 48v-14M56 48v-20M64 48v-14M72 48v-20"/>
      <path d="M48 72v14M56 72v20M64 72v14M72 72v20"/>
    </g>
    <circle cx="60" cy="60" r="3"/>
  </svg>
)}
{name === 'moth' && (
  <svg class={cls} style={style} viewBox="0 0 140 120" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
    <line x1="70" y1="34" x2="70" y2="92"/>
    <path d="M70 40 C40 18, 8 30, 14 56 C18 76, 48 78, 70 64"/>
    <path d="M70 40 C100 18, 132 30, 126 56 C122 76, 92 78, 70 64"/>
    <path d="M70 66 C52 70, 36 84, 44 100 C52 110, 68 92, 70 82"/>
    <path d="M70 66 C88 70, 104 84, 96 100 C88 110, 72 92, 70 82"/>
    <path d="M70 34 C66 24, 60 20, 56 16M70 34 C74 24, 80 20, 84 16"/>
    <path d="M30 46h22M88 46h22" stroke-width="1"/>
  </svg>
)}
{name === 'neuron' && (
  <svg class={cls} style={style} viewBox="0 0 140 120" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
    <g stroke-width="1">
      <path d="M24 30 L70 24 M24 30 L66 60 M24 30 L40 96"/>
      <path d="M70 24 L116 36 M70 24 L66 60 M66 60 L116 36 M66 60 L104 92 M40 96 L66 60 M40 96 L104 92"/>
    </g>
    <circle cx="24" cy="30" r="6"/><circle cx="70" cy="24" r="7"/>
    <circle cx="116" cy="36" r="6"/><circle cx="66" cy="60" r="8"/>
    <circle cx="40" cy="96" r="6"/><circle cx="104" cy="92" r="6"/>
  </svg>
)}
{name === 'scope' && (
  <svg class={cls} style={style} viewBox="0 0 100 140" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
    <path d="M40 14 L40 40 L28 64"/>
    <path d="M40 14 L52 14 L52 38"/>
    <circle cx="40" cy="14" r="5"/>
    <path d="M28 64 C20 80, 22 96, 40 100"/>
    <path d="M40 40 C58 44, 64 70, 50 96"/>
    <rect x="26" y="100" width="48" height="8" rx="2"/>
    <path d="M30 108 L34 128 L66 128 L70 108"/>
    <line x1="36" y1="116" x2="64" y2="116" stroke-width="1"/>
  </svg>
)}
{name === 'atom' && (
  <svg class={cls} style={style} viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
    <circle cx="60" cy="60" r="6"/>
    <ellipse cx="60" cy="60" rx="48" ry="18"/>
    <ellipse cx="60" cy="60" rx="48" ry="18" transform="rotate(60 60 60)"/>
    <ellipse cx="60" cy="60" rx="48" ry="18" transform="rotate(120 60 60)"/>
    <circle cx="108" cy="60" r="3"/><circle cx="36" cy="18" r="3"/><circle cx="36" cy="102" r="3"/>
  </svg>
)}
{name === 'flask' && (
  <svg class={cls} style={style} viewBox="0 0 100 130" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
    <path d="M40 12 h20 M44 12 v30 L24 96 a8 8 0 0 0 7 13 h38 a8 8 0 0 0 7 -13 L56 42 V12"/>
    <path d="M33 78 h34"/>
    <circle cx="44" cy="88" r="2.4" fill="currentColor" stroke="none"/>
    <circle cx="56" cy="94" r="1.8" fill="currentColor" stroke="none"/>
    <circle cx="50" cy="84" r="1.4" fill="currentColor" stroke="none"/>
  </svg>
)}
