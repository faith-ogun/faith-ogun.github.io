---
export interface Props {
  index: string;     // e.g. "02"
  label: string;     // eyebrow
  title: string;     // big title
  blurb: string;     // what's coming
  phase: string;     // which phase ships this
}
const { index, label, title, blurb, phase } = Astro.props;
---
<section class="cs">
  <div class="container-narrow cs-inner">
    <span class="cs-index">{index}</span>
    <p class="eyebrow center">{label}</p>
    <h1 class="cs-title display">{title}</h1>
    <p class="lead cs-blurb">{blurb}</p>
    <p class="cs-phase">{phase}</p>
    <a href="/" class="btn btn-ghost">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Back to home
    </a>
  </div>
</section>

<style>
  .cs { min-height: 78vh; display: grid; place-items: center; text-align: center; padding-top: 8rem; }
  .cs-inner { display: flex; flex-direction: column; align-items: center; gap: 1.1rem; }
  .cs-index { font-family: var(--font-display); font-size: clamp(4rem, 14vw, 9rem); line-height: 0.9; color: var(--paper-3); font-weight: 700; }
  .cs-title { font-size: clamp(2.4rem, 6vw, 4rem); color: var(--ink); }
  .cs-blurb { max-width: 52ch; }
  .cs-phase {
    font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--accent); border: 1px solid var(--accent-soft); background: var(--accent-soft);
    padding: 0.4rem 0.9rem; border-radius: 999px; margin-top: 0.4rem;
  }
  .cs .btn { margin-top: 1.25rem; }
</style>
