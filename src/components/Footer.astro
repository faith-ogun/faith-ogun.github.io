---
const year = new Date().getFullYear();
---
<footer class="foot">
  <div class="container foot-inner">
    <div class="foot-mark">
      <!-- quirky engraved motif: a little benchtop flask, hand-drawn -->
      <svg viewBox="0 0 64 72" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
        <path d="M26 6h12M28 6v16L14 52a6 6 0 0 0 5.4 9h25.2A6 6 0 0 0 50 52L36 22V6"/>
        <path d="M21 42h22" />
        <circle cx="27" cy="50" r="1.6" fill="currentColor" stroke="none"/>
        <circle cx="35" cy="54" r="1.2" fill="currentColor" stroke="none"/>
        <circle cx="31" cy="46" r="1" fill="currentColor" stroke="none"/>
        <path d="M44 14c3-2 6-1 7 2" />
        <path d="M52 9l1.5 2.5M55 14l2.5 1" />
      </svg>
      <p class="foot-tag">Curiosity, decoded.</p>
    </div>

    <nav class="foot-links" aria-label="Footer">
      <a href="/about" class="ulink">About</a>
      <a href="/research" class="ulink">Research</a>
      <a href="/projects" class="ulink">Projects</a>
      <a href="/blog" class="ulink">Blog</a>
      <a href="/startup" class="ulink">Startup</a>
    </nav>

    <div class="foot-social">
      <a href="https://github.com/faith-ogun" target="_blank" rel="noopener" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
      <a href="https://linkedin.com/in/faith-ogundimu" target="_blank" rel="noopener" aria-label="LinkedIn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
      </a>
      <a href="mailto:faithogundimu25@rcsi.ie" aria-label="Email">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
      </a>
    </div>
  </div>
  <div class="container foot-base">
    <span>© {year} Faith Ogundimu</span>
    <span>Royal College of Surgeons in Ireland · Genomics &amp; Machine Learning</span>
  </div>
</footer>

<style>
  .foot { background: var(--night); color: var(--paper); padding-block: 3.5rem 1.75rem; }
  .foot-inner { display: grid; grid-template-columns: 1.4fr 1fr auto; gap: 2.5rem; align-items: center; }
  .foot-mark { display: flex; align-items: center; gap: 1rem; }
  .foot-mark svg { width: 42px; height: auto; color: var(--accent); flex: none; }
  .foot-tag { font-family: var(--font-display); font-style: italic; font-size: 1.35rem; color: var(--paper); }
  .foot-links { display: flex; flex-wrap: wrap; gap: 1.25rem; font-family: var(--font-mono); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .foot-links .ulink { color: var(--paper); }
  .foot-social { display: flex; gap: 0.9rem; }
  .foot-social a { width: 42px; height: 42px; display: grid; place-items: center; border: 1px solid rgba(245,239,227,0.22); border-radius: 50%; color: var(--paper); transition: all 0.3s var(--ease); }
  .foot-social a:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }
  .foot-base {
    margin-top: 2.75rem; padding-top: 1.5rem; border-top: 1px solid rgba(245,239,227,0.14);
    display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
    font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.06em; color: rgba(245,239,227,0.6);
  }
  @media (max-width: 820px) {
    .foot-inner { grid-template-columns: 1fr; gap: 1.75rem; text-align: left; }
    .foot-base { flex-direction: column; }
  }
</style>
