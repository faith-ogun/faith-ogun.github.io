---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
const featured = posts[0];
const rest = posts.slice(1);
---
<BaseLayout
  title="Journal Club · Faith Ogundimu"
  description="Critical reads of landmark papers in non-coding cancer genomics, deep learning and gene regulation, connecting the literature to my PhD work, with animated explainers."
>
  <section class="blog-hero">
    <div class="container">
      <p class="eyebrow">Journal Club</p>
      <h1 class="blog-title display">Reading the literature, <span class="nc squiggle">out loud</span>.</h1>
      <p class="blog-lead lead">
        Deep, critical reads of the papers shaping non-coding cancer genomics, regulatory deep
        learning and 3D genome biology, each one tied back to what I'm building in my PhD, with
        animated explainers for the hard bits.
      </p>
    </div>
  </section>

  <section class="blog-list-sec">
    <div class="container">
      {featured && (
        <a href={`/blog/${featured.id}/`} class="feature-card reveal">
          <div class="feature-body">
            <p class="feature-kicker">{featured.data.heroKicker ?? 'Latest'}</p>
            <h2 class="feature-title display">{featured.data.title}</h2>
            <p class="feature-desc">{featured.data.description}</p>
            <div class="post-meta">
              <span>{fmt(featured.data.date)}</span>
              {featured.data.readingTime && <span>· {featured.data.readingTime}</span>}
              <span>· {featured.data.papers.length} paper{featured.data.papers.length === 1 ? '' : 's'}</span>
            </div>
            <span class="feature-go">Read the analysis <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
          </div>
        </a>
      )}

      <div class="post-grid" id="post-grid">
        {rest.map((p, i) => (
          <a href={`/blog/${p.id}/`} class="post-card spec-card reveal" data-i={i}>
            <p class="post-kicker">{p.data.heroKicker ?? 'Journal Club'}</p>
            <h3 class="post-card-title">{p.data.title}</h3>
            <p class="post-card-desc">{p.data.description}</p>
            <div class="post-meta">
              <span>{fmt(p.data.date)}</span>
              {p.data.readingTime && <span>· {p.data.readingTime}</span>}
            </div>
            <div class="post-tags">
              {p.data.tags.slice(0, 3).map((t) => <span class="post-tag">{t}</span>)}
            </div>
          </a>
        ))}
      </div>

      <div class="pager" id="blog-pager" hidden>
        <button class="pager-btn" data-dir="-1" type="button" aria-label="Previous posts">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <span class="pager-indicator" id="blog-pager-ind">1 / 1</span>
        <button class="pager-btn" data-dir="1" type="button" aria-label="Next posts">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <script>
    const grid = document.getElementById('post-grid');
    const pager = document.getElementById('blog-pager');
    if (grid && pager) {
      const cards = Array.from(grid.querySelectorAll('.post-card')) as HTMLElement[];
      const perPage = 6;
      const pages = Math.ceil(cards.length / perPage);
      const ind = document.getElementById('blog-pager-ind')!;
      const prev = pager.querySelector('[data-dir="-1"]') as HTMLButtonElement;
      const next = pager.querySelector('[data-dir="1"]') as HTMLButtonElement;
      let page = 0;
      const render = () => {
        const start = page * perPage;
        cards.forEach((c, i) => {
          const on = i >= start && i < start + perPage;
          c.style.display = on ? '' : 'none';
          if (on) c.classList.add('in');
        });
        ind.textContent = `${page + 1} / ${pages}`;
        prev.disabled = page === 0;
        next.disabled = page === pages - 1;
      };
      if (pages > 1) {
        pager.hidden = false;
        prev.addEventListener('click', () => { if (page > 0) { page--; render(); grid.scrollIntoView({ behavior: 'smooth', block: 'start' }); } });
        next.addEventListener('click', () => { if (page < pages - 1) { page++; render(); grid.scrollIntoView({ behavior: 'smooth', block: 'start' }); } });
        render();
      }
    }
  </script>
</BaseLayout>

<style>
  .blog-hero { padding-top: clamp(8rem, 16vh, 11rem); padding-bottom: clamp(2rem, 5vh, 3.5rem); }
  .blog-title { font-size: clamp(2.6rem, 6.5vw, 4.6rem); font-weight: 700; color: var(--ink); margin: 1.1rem 0 1.2rem; max-width: 16ch; }
  .blog-title .nc { color: var(--blue-primary); font-style: italic; }
  .blog-lead { max-width: 60ch; }

  .blog-list-sec { padding-top: 1rem; }
  .feature-card { display: block; background: var(--blue-primary); color: #fff; border-radius: 20px; padding: clamp(2rem, 5vw, 3.5rem); margin-bottom: 2.5rem; transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease); }
  .feature-card:hover { transform: translateY(-4px); box-shadow: 0 28px 60px rgba(59,76,202,0.3); }
  .feature-kicker { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.8); margin-bottom: 0.8rem; }
  .feature-title { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 700; line-height: 1.1; margin-bottom: 1rem; max-width: 22ch; }
  .feature-desc { color: rgba(255,255,255,0.85); font-size: 1.05rem; line-height: 1.6; max-width: 60ch; margin-bottom: 1.2rem; }
  .feature-go { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: #fff; }
  .feature-go svg { width: 16px; height: 16px; transition: transform 0.3s var(--ease); }
  .feature-card:hover .feature-go svg { transform: translateX(4px); }

  .post-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.4rem; }
  .post-card { display: flex; flex-direction: column; gap: 0.6rem; }
  .post-kicker { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); }
  .post-card-title { font-family: var(--font-display); font-size: 1.35rem; font-weight: 600; line-height: 1.25; color: var(--ink); }
  .post-card:hover .post-card-title { color: var(--blue-primary); }
  .post-card-desc { font-size: 0.92rem; color: var(--ink-2); line-height: 1.55; flex: 1; }

  .post-meta { display: flex; flex-wrap: wrap; gap: 0.4rem; font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink-3); }
  .feature-card .post-meta { color: rgba(255,255,255,0.75); margin-bottom: 1.2rem; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.2rem; }
  .post-tag { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.04em; text-transform: uppercase; color: var(--blue-primary); background: var(--blue-pale); border-radius: 999px; padding: 0.25rem 0.6rem; }
</style>
