---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImgSlot from '../components/ImgSlot.astro';
import { news } from '../data/news';

const featured = news.find((n) => n.featured);
const rest = news.filter((n) => !n.featured);
---
<BaseLayout
  title="News & Achievements — Faith Ogundimu"
  description="Awards, grants, talks and hackathon wins from Faith Ogundimu — PhD researcher in cancer genomics and machine learning at RCSI."
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">News &amp; achievements</p>
      <h1 class="page-title display">The <span class="nc squiggle">latest</span> from the bench.</h1>
      <p class="page-lead lead">Awards, grants, talks and the occasional hackathon trophy — a running record of what I've been up to.</p>
    </div>
  </section>

  <section class="news-page">
    <div class="container">
      {featured && (
        <article class="news-feature reveal">
          <ImgSlot src={featured.img} label="Add image" ratio="16/10" class="news-feature-img" />
          <div class="news-feature-body">
            <div class="news-card-meta"><span class="news-tag">{featured.tag}</span><span>{featured.display}</span></div>
            <h2 class="news-feature-title display">{featured.title}</h2>
            <p class="news-feature-venue">{featured.venue}</p>
            <div class="news-links">{featured.links.map((l) => (
              <a href={l.href} target="_blank" rel="noopener" class="news-link">{l.label}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M7 7h10v10"/></svg></a>
            ))}</div>
          </div>
        </article>
      )}

      <div class="news-grid">
        {rest.map((n, i) => (
          <article class="news-card reveal" style={`transition-delay:${(i % 3) * 0.06}s`}>
            <ImgSlot src={n.img} label="Add image" ratio="16/10" />
            <div class="news-card-body">
              <div class="news-card-meta"><span class="news-tag">{n.tag}</span><span>{n.display}</span></div>
              <h3 class="news-card-title">{n.title}</h3>
              <p class="news-card-venue">{n.venue}</p>
              <div class="news-links">{n.links.map((l) => (
                <a href={l.href} target="_blank" rel="noopener" class="news-link">{l.label}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M7 7h10v10"/></svg></a>
              ))}</div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { padding-top: clamp(8rem, 16vh, 11rem); padding-bottom: clamp(1.5rem, 4vh, 3rem); }
  .page-title { font-size: clamp(2.6rem, 6.5vw, 4.6rem); font-weight: 700; color: var(--ink); margin: 1.1rem 0 1.1rem; }
  .page-title .nc { color: var(--blue-primary); font-style: italic; }
  .page-lead { max-width: 56ch; }

  .news-page { padding-top: 1.5rem; }
  .news-card-meta { display: flex; align-items: center; gap: 0.7rem; font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 0.7rem; }
  .news-tag { color: var(--accent); border: 1px solid var(--accent-soft); background: var(--accent-soft); padding: 0.2rem 0.55rem; border-radius: 999px; }
  .news-links { display: flex; flex-wrap: wrap; gap: 1.1rem; margin-top: 0.9rem; }
  .news-link { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--blue-primary); }
  .news-link svg { width: 13px; height: 13px; transition: transform 0.3s var(--ease); }
  .news-link:hover { color: var(--accent); }
  .news-link:hover svg { transform: translate(2px, -2px); }

  /* featured */
  .news-feature { display: grid; grid-template-columns: 1.1fr 1fr; gap: clamp(1.5rem, 4vw, 3rem); align-items: center; background: var(--paper-2); border-radius: 20px; padding: clamp(1.2rem, 3vw, 1.6rem); margin-bottom: 2.5rem; }
  .news-feature-img { width: 100%; }
  .news-feature-title { font-size: clamp(1.6rem, 3.4vw, 2.4rem); font-weight: 700; line-height: 1.15; color: var(--ink); margin-bottom: 0.8rem; }
  .news-feature-venue { font-size: 1.02rem; color: var(--ink-2); line-height: 1.6; }

  /* grid */
  .news-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.6rem; }
  .news-card { display: flex; flex-direction: column; border: 1px solid var(--hairline); border-radius: 16px; overflow: hidden; background: var(--paper); transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease), border-color 0.35s var(--ease); }
  .news-card:hover { transform: translateY(-4px); box-shadow: 0 18px 40px rgba(27,27,42,0.08); border-color: rgba(59,76,202,0.2); }
  .news-card-body { padding: 1.3rem 1.4rem 1.5rem; display: flex; flex-direction: column; flex: 1; }
  .news-card-title { font-family: var(--font-display); font-size: 1.2rem; font-weight: 600; line-height: 1.3; color: var(--ink); margin-bottom: 0.5rem; }
  .news-card-venue { font-size: 0.92rem; color: var(--ink-2); line-height: 1.55; flex: 1; }

  @media (max-width: 760px) {
    .news-feature { grid-template-columns: 1fr; }
  }
</style>
