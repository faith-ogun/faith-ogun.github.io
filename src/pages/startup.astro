---
import BaseLayout from '../layouts/BaseLayout.astro';

const ventures = [
  {
    key: 'ohmlet', href: '/startup/ohmlet', name: 'Ohmlet', img: '/assets/ohmlet/mascot.png',
    tagline: 'Learn electronics by building, with an AI tutor that watches your bench.',
    tags: ['Consumer', 'EdTech', 'Voice + Vision'], status: 'In construction',
  },
  {
    key: 'onkydra', href: '/startup/onkydra', name: 'Onkydra', img: '/assets/onkydra/mark-white.png',
    tagline: 'Simulate rare cancers in-silico to find treatments faster.',
    tags: ['Biotech', 'In-silico', 'Rare cancer'], status: 'In construction',
  },
];
---
<BaseLayout
  title="Startup Corner · Faith Ogundimu"
  description="Two ventures I'm building: Ohmlet, a live AI tutor for electronics, and Onkydra, an in-silico oncology lab simulating rare cancers to speed up drug discovery."
>
  <!-- Intro framing -->
  <section class="su-intro">
    <div class="container-narrow">
      <p class="eyebrow center">Startup Corner</p>
      <h1 class="su-title display">Two ventures. One <span class="nc squiggle">curiosity</span>.</h1>
      <p class="su-lead lead">Research is one half of what I do. The other is building. Two ventures, two completely different worlds: one teaches anyone to build electronics with an AI that can see your bench, the other simulates rare cancers to help find treatments faster. Pick a door.</p>
    </div>
  </section>

  <!-- Two doors -->
  <section class="su-doors-sec">
    <div class="container">
      <div class="su-doors">
        {ventures.map((v) => (
          <a href={v.href} class:list={['door', `door-${v.key}`, 'reveal']}>
            <div class="door-top">
              <span class="door-status"><span class="door-dot"></span> {v.status}</span>
              <span class="door-enter">Enter <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
            </div>
            <div class="door-art"><img src={v.img} alt={`${v.name} logo`} /></div>
            <div class="door-body">
              <h2 class="door-name">{v.name}</h2>
              <p class="door-tagline">{v.tagline}</p>
              <div class="door-tags">{v.tags.map((t) => <span class="door-tag">{t}</span>)}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .su-intro { padding-top: clamp(8rem, 16vh, 11rem); padding-bottom: clamp(2.5rem, 6vh, 4rem); text-align: center; }
  .su-title { font-size: clamp(2.6rem, 6.5vw, 4.6rem); font-weight: 700; color: var(--ink); margin: 1.1rem 0 1.2rem; }
  .su-title .nc { color: var(--blue-primary); font-style: italic; }
  .su-lead { max-width: 60ch; margin-inline: auto; }

  .su-doors-sec { padding-top: 0; padding-bottom: clamp(4rem, 9vh, 7rem); }
  .su-doors { display: grid; grid-template-columns: 1fr 1fr; gap: 1.6rem; }

  .door {
    position: relative; display: flex; flex-direction: column; gap: 1.4rem;
    min-height: 460px; padding: clamp(1.6rem, 3vw, 2.4rem); border-radius: 26px; overflow: hidden;
    transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease);
  }
  .door::after { content: ""; position: absolute; inset: 0; border-radius: 26px; border: 1.5px solid rgba(255,255,255,0.18); pointer-events: none; }
  .door:hover { transform: translateY(-8px); }

  .door-top { display: flex; align-items: center; justify-content: space-between; position: relative; z-index: 2; }
  .door-status { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-mono); font-size: 0.66rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.4rem 0.8rem; border-radius: 999px; }
  .door-dot { width: 7px; height: 7px; border-radius: 50%; animation: door-pulse 1.8s ease-in-out infinite; }
  @keyframes door-pulse { 0%,100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.3); opacity: 0.6; } }
  .door-enter { display: inline-flex; align-items: center; gap: 0.45rem; font-family: var(--font-mono); font-size: 0.72rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; }
  .door-enter svg { width: 15px; height: 15px; transition: transform 0.3s var(--ease); }
  .door:hover .door-enter svg { transform: translateX(5px); }

  .door-art { flex: 1; display: grid; place-items: center; position: relative; z-index: 2; }
  .door-art img { max-height: 190px; width: auto; transition: transform 0.5s var(--ease); }
  .door:hover .door-art img { transform: scale(1.06); }

  .door-body { position: relative; z-index: 2; }
  .door-name { font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 800; line-height: 1; margin-bottom: 0.7rem; }
  .door-tagline { font-size: 1.02rem; line-height: 1.5; margin-bottom: 1rem; max-width: 34ch; }
  .door-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .door-tag { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.3rem 0.7rem; border-radius: 999px; }

  /* OHMLET door: yellow / black */
  .door-ohmlet { background: radial-gradient(120% 120% at 80% 0%, #FFDC4A 0%, #FFD21E 55%, #FBC400 100%); color: #1B1B1B; box-shadow: 0 18px 40px rgba(251,196,0,0.28); }
  .door-ohmlet .door-status { background: rgba(27,27,27,0.1); color: #1B1B1B; }
  .door-ohmlet .door-dot { background: #EA3C2D; }
  .door-ohmlet .door-name { font-family: var(--font-body); color: #1B1B1B; }
  .door-ohmlet .door-tagline { color: rgba(27,27,27,0.78); font-family: var(--font-body); font-weight: 500; }
  .door-ohmlet .door-tag { background: rgba(27,27,27,0.1); color: #1B1B1B; }
  .door-ohmlet:hover { box-shadow: 0 26px 56px rgba(251,196,0,0.42); }
  .door-ohmlet .door-art img { filter: drop-shadow(0 14px 26px rgba(0,0,0,0.18)); }

  /* ONKYDRA door: ink / electric blue */
  .door-onkydra { background: radial-gradient(120% 120% at 80% 0%, #1a1c4d 0%, #0e0f23 60%); color: #f6f4ef; box-shadow: 0 18px 40px rgba(14,15,35,0.4); }
  .door-onkydra .door-status { background: rgba(6,0,249,0.18); color: #8b95ff; }
  .door-onkydra .door-dot { background: #0600f9; box-shadow: 0 0 8px #0600f9; }
  .door-onkydra .door-enter { color: #eab308; }
  .door-onkydra .door-name { font-family: 'Comfortaa', var(--font-body); color: #fff; letter-spacing: -0.02em; }
  .door-onkydra .door-tagline { color: rgba(246,244,239,0.72); }
  .door-onkydra .door-tag { background: rgba(246,244,239,0.08); color: rgba(246,244,239,0.75); }
  .door-onkydra:hover { box-shadow: 0 26px 56px rgba(6,0,249,0.32); }
  .door-onkydra .door-art img { max-height: 150px; filter: drop-shadow(0 0 30px rgba(6,0,249,0.5)); }

  @media (max-width: 760px) {
    .su-doors { grid-template-columns: 1fr; }
    .door { min-height: 380px; }
  }
</style>
